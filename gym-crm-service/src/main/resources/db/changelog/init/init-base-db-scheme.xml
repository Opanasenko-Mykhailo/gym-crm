<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.21.xsd">

    <changeSet id="GCA-49-create-users-table" author="Opanasenko-Mykhailo">
        <createTable tableName="users">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="GCA-49-create-training-types-table" author="Opanasenko-Mykhailo">
        <createTable tableName="training_types">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="training_type_name" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="GCA-49-create-trainees-table" author="Opanasenko-Mykhailo">
        <createTable tableName="trainees">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="date_of_birth" type="DATE"/>
            <column name="address" type="VARCHAR(255)"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_trainee_user" referencedTableName="users"
                             referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="GCA-49-create-trainers-table" author="Opanasenko-Mykhailo">
        <createTable tableName="trainers">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="specialization_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_trainer_specialization"
                             referencedTableName="training_types" referencedColumnNames="id"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_trainer_user" referencedTableName="users"
                             referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="GCA-49-create-trainings-table" author="Opanasenko-Mykhailo">
        <createTable tableName="trainings">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="training_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="training_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="training_duration" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="trainee_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_training_trainee" referencedTableName="trainees"
                             referencedColumnNames="id"/>
            </column>
            <column name="trainer_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_training_trainer" referencedTableName="trainers"
                             referencedColumnNames="id"/>
            </column>
            <column name="type_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_training_type" referencedTableName="training_types"
                             referencedColumnNames="id"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="GCA-49-create-trainee-trainer-join-table" author="Opanasenko-Mykhailo">
        <createTable tableName="trainee_trainer">
            <column name="trainee_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="trainer_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addPrimaryKey
                tableName="trainee_trainer"
                columnNames="trainee_id, trainer_id"
                constraintName="pk_trainee_trainer"/>
        <addForeignKeyConstraint
                constraintName="fk_trainee_trainer__trainee_id"
                baseTableName="trainee_trainer"
                baseColumnNames="trainee_id"
                referencedTableName="trainees"
                referencedColumnNames="id"/>
        <addForeignKeyConstraint
                constraintName="fk_trainee_trainer__trainer_id"
                baseTableName="trainee_trainer"
                baseColumnNames="trainer_id"
                referencedTableName="trainers"
                referencedColumnNames="id"/>
    </changeSet>
</databaseChangeLog>
